# EditorConfig helps maintain consistent coding styles across editors and IDEs.
# https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

########################
## Web

[*.{js,jsx}]
indent_size = 2

[*.{ts,tsx}]
indent_size = 2

[*.html]
indent_size = 2

[*.css]
indent_size = 2

########################
## Data / Config

[*.{yml,yaml}]
indent_size = 2

[*.json]
indent_size = 2

[*.toml]
indent_size = 2

[*.xml]
indent_size = 2

[*.ini]
indent_size = 4

[*.conf]
indent_size = 4

[*.env]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = false

########################
## Infrastructure / IaC

[*.tf]
indent_size = 2

[*.tfvars]
indent_size = 2

[*.proto]
indent_size = 2

########################
## Backend

[*.py]
indent_size = 4
max_line_length = 88

[*.rb]
indent_size = 2

[*.go]
indent_style = tab
indent_size = 4
tab_width = 4

[*.rs]
indent_size = 4

[*.java]
indent_size = 4

[*.kt]
indent_size = 4

[*.php]
indent_size = 4

[*.swift]
indent_size = 4

[*.{c,h}]
indent_size = 4

[*.{cpp,hpp}]
indent_size = 4

[*.cs]
indent_size = 4

########################
## Shell & Scripts

[*.sh]
indent_size = 2

[*.bash]
indent_size = 2

########################
## Database

[*.sql]
indent_size = 2

########################
## Docs

[*.md]
trim_trailing_whitespace = false
indent_size = 4
insert_final_newline = false

########################
## Build tools

[Makefile]
indent_style = tab

[Dockerfile]
indent_size = 4

########################
## Auto-generated / binary-adjacent (do not reformat)

[*.lock]
trim_trailing_whitespace = false
insert_final_newline = false

[*.{min.js,min.css}]
trim_trailing_whitespace = false
insert_final_newline = false

[*.svg]
trim_trailing_whitespace = false
