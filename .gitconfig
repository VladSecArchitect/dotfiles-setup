[core]
    editor = subl -n -w
    excludesfile = ~/.gitignore
    autocrlf = input
    pager = diff-so-fancy | less --tabs=4 -RFX

[color]
    ui = auto

[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green

[color "diff"]
    meta = yellow bold
    frag = magenta bold
    old = red bold
    new = green bold

[color "status"]
    added = green
    changed = yellow
    untracked = cyan

[credential]
    helper = osxkeychain

[status]
    showUntrackedFiles = all

[help]
    autocorrect = 1

[pager]
    difftool = true

[merge]
    # Include summaries of merged commits in newly created merge commit messages
    log = true
    tool = opendiff

[diff]
    tool = opendiff

[alias]
    # View the SHA, description, and history graph of the latest 20 commits
    l = log --pretty=oneline -n 20 --graph
    # View the current working tree status using the short format
    s = status
    # Diff
    d = diff --patch-with-stat
    # Pull in remote changes for the current repository and all its submodules
    p = !"git pull; git submodule foreach git pull origin master"
    # Commit all changes and add message inline
    ca = !git add -A && git commit -avm
    # Commit changes, add any necessary files, and add message in editor
    c = commit -a
    # Switch to a branch, creating it if necessary
    go = checkout -B
    # Show verbose output about tags, branches or remotes
    tags = tag -l
    branches = branch -a
    rv = remote -v
    # Credit an author on the latest commit
    credit = "!f() { git commit --amend --author \"$1 <$2>\" -C HEAD; }; f"
    # Get a list of files from the last commit(s)
    last-commit = diff --name-only HEAD~1 HEAD
    # Grab the commits in the last X days and pretty print the files
    time = "!f() { git log --pretty=format: --name-only --since=\"$1 days ago\"; }; f"
    # Find tags containing commit
    find-tags = "!f() { git describe --always --contains $1; }; f"
    # Find commits by source code
    find-commits = "!f() { git log --pretty=format:'%C(yellow)%h  %Cblue%ad  %Creset%s%Cgreen  [%cn] %Cred%d' --decorate --date=short -S$1; }; f"
    # Find commits by commit message
    find-messages = "!f() { git log --pretty=format:'%C(yellow)%h  %Cblue%ad  %Creset%s%Cgreen  [%cn] %Cred%d' --decorate --date=short --grep=$1; }; f"
    # Undo a `git push`
    undopush = push -f origin HEAD^:master
    # Reset the current edited files back to the last commit
    rh = reset --hard
    # Pull everything
    pa = pull --all
    # Push everything to a shared repo
    psa = push shared --all

# URL shorthands
[url "git@github.com:"]
    insteadOf = "gh:"
    pushInsteadOf = "github:"
    pushInsteadOf = "git://github.com/"
[url "git://github.com/"]
    insteadOf = "github:"
[url "git@gist.github.com:"]
    insteadOf = "gst:"
    pushInsteadOf = "gist:"
    pushInsteadOf = "git://gist.github.com/"
[url "git://gist.github.com/"]
    insteadOf = "gist:"
[push]
    default = simple

[pull]
    rebase = false

[init]
    defaultBranch = main
