#!/usr/bin/env bash
# ~/.extra — machine-specific overrides, NOT committed to version control
# Copy to ~/.extra and fill in your values.
# Sourced by ~/.bash_profile after all other dotfiles.
#
# Pattern from: https://github.com/mathiasbynens/dotfiles

# Git identity
GIT_AUTHOR_NAME="Your Name"
GIT_COMMITTER_NAME="$GIT_AUTHOR_NAME"
git config --global user.name "$GIT_AUTHOR_NAME"

GIT_AUTHOR_EMAIL="you@example.com"
GIT_COMMITTER_EMAIL="$GIT_AUTHOR_EMAIL"
git config --global user.email "$GIT_AUTHOR_EMAIL"

# API tokens and secrets
# export GITHUB_TOKEN=""
# export OPENAI_API_KEY=""
# export AWS_ACCESS_KEY_ID=""
# export AWS_SECRET_ACCESS_KEY=""

# Machine-specific PATH additions
# export PATH="$HOME/work/bin:$PATH"

# RVM (Ruby Version Manager)
# export PATH="$PATH:$HOME/.rvm/bin"
# [[ -s "$HOME/.rvm/scripts/rvm" ]] && source "$HOME/.rvm/scripts/rvm"

# NVM (Node Version Manager)
# export NVM_DIR="$HOME/.nvm"
# [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
# [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
