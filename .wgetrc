# Use the server-provided last modification date, if available
# Включить/выключить использование отметок времени; то же что -N
timestamping = on

# Do not go up in the directory structure when downloading recursively
# Запретить поиск вне каталожной иерархии, то же что -no-parent.
no_parent = on

# Wait 60 seconds before timing out. This applies to all timeouts: DNS, connect and read. (The default read timeout is 15 minutes!)
# Установить значение максимального ожидания ответа; то же что -T.
timeout = 60

# Retry a few times when a download fails, but don’t overdo it. (The default is 20!)
# Установить число повторов на URL; то же что -t
tries = 3

# Retry even when the connection was refused
retry_connrefused = on

# Use the last component of a redirection URL for the local file name
trust_server_names = on

# Follow FTP links from HTML documents by default
# Следовать всем FTP линкам в документе HTML, то же, что -f
follow_ftp = on

# Add a `.html` extension to `text/html` or `application/xhtml+xml` files that lack one, or a `.css` extension to `text/css` files that lack one
adjust_extension = on

# Use UTF-8 as the default system encoding
# Disabled as it makes `wget` builds that don’t support this feature unusable.
# Does anyone know how to conditionally configure a wget setting?
# http://unix.stackexchange.com/q/34730/6040
#local_encoding = UTF-8

# Ignore `robots.txt` and `<meta name=robots content=nofollow>`
# Использовать (on) или не использовать файл /robots.txt. Умолчание: on. Если задумаете менять умолчание, то постарайтесь ясно понять результат.
robots = off

# Print the HTTP and FTP server responses
# Включить/выключить печати ответов серверов HTTP и FTP; то же что -S
server_response = on

# Disguise as IE 9 on Windows 7
user_agent = Mozilla/5.0 (compatible; MSIE 9.0; Windows NT 6.1; Trident/5.0)
