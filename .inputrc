# GNU Readline configuration
# https://www.gnu.org/software/bash/manual/html_node/Readline-Init-File.html

# Load system-wide defaults first
$include /etc/inputrc

########################
## Completion behaviour

# Case-insensitive tab completion (Desktop matches desktop)
set completion-ignore-case on

# Treat - and _ as equivalent in completion
set completion-map-case on

# Show all matches immediately on ambiguous completion (no double-tab needed)
set show-all-if-ambiguous on

# Also show matches when nothing new was typed since last completion
set show-all-if-unmodified on

# Skip the part of the word already typed when inserting a completion
set skip-completed-text on

# If there are more than 200 possible completions, ask before showing them all
set completion-query-items 200

# Append / to symlinked directories in completion list
set mark-symlinked-directories on

########################
## Visual feedback

# Color file types in completion list using $LS_COLORS
set colored-stats on

# Append file-type indicator to completions (/ for dirs, * for executables)
set visible-stats on

# Highlight the common prefix of completions in a different color (Readline 7+)
set colored-completion-prefix on

# Show completion list within one page without paging
set page-completions off

########################
## Editing

# No bell — neither audible nor visible
set bell-style none

# Allow UTF-8 characters to be inserted directly
set input-meta on
set output-meta on
set convert-meta off

# Bracketed paste: prevents pasted newlines from auto-executing commands
# Important for security — paste is shown in buffer first, not run immediately
set enable-bracketed-paste on

# Keep cursor position when navigating history (not jump to end of line)
set history-preserve-point on

# Revert any edits made to a history entry when accepting a different line
set revert-all-at-newline on

# Multi-key sequence timeout in ms (lower = less lag in tmux/SSH)
set keyseq-timeout 200

########################
## Display

# Show completions horizontally (saves vertical space)
set print-completions-horizontally on

# Auto-fit completion columns to terminal width
set completion-display-width 0

########################
## History search (arrow keys search by current prefix)

"\e[A": history-search-backward
"\e[B": history-search-forward

# Same for Ctrl+P / Ctrl+N
"\C-p": history-search-backward
"\C-n": history-search-forward

# Home / End keys
"\e[H": beginning-of-line
"\e[F": end-of-line

# Ctrl+Left / Ctrl+Right — jump by word
"\e[1;5D": backward-word
"\e[1;5C": forward-word

# Shift+Tab — cycle through completions one by one
"\e[Z": menu-complete

# Alt+Backspace — delete previous word
"\e\C-h": backward-kill-word
"\e[3;3~": kill-word

# Ctrl+X Ctrl+E — expand aliases/variables on current line
"\C-x\C-e": shell-expand-line

# Alt+* — expand glob pattern in place (ls /etc/nginx/*.c → ls /etc/nginx/file1.c ...)
"\e*": glob-expand-word

# Alt+# — comment out current line and move to next history entry (save for later)
"\e#": insert-comment

# Ctrl+O — execute current line then fetch the next history entry (great for replaying sequences)
"\C-o": operate-and-get-next
